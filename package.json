    "test:auth": "node_modules/.bin/playwright test --project=authenticated",
    "test:screenshots": "node_modules/.bin/playwright test --project=screenshots",
    "codegen": "node_modules/.bin/playwright codegen https://solar.coffeerunhobby.ro"
  },
  "devDependencies": {
    "@gfx/zopfli": "^1.0.15",
